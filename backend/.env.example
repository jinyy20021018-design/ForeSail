USE_LLM_EXTRACTION=true
USE_LLM_SUMMARY=true
REQUIRE_LLM_AGENT=true
USE_LLM_RELEVANCE_FACTORS=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- LLM provider ---------------------------------------------------------
# ForeSail's optional LLM features (document field extraction, agent run
# summary, relevance-factor / news-event extraction) run against a single
# provider. Google Gemini is the default whenever a Gemini key is set (or
# LLM_PROVIDER=gemini); it is reached through Gemini's OpenAI-compatible
# endpoint, so the request shape is identical across providers.
LLM_PROVIDER=gemini
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Optional per-purpose overrides: GEMINI_SUMMARY_MODEL, GEMINI_EXTRACTION_MODEL,
# GEMINI_RELEVANCE_FACTOR_MODEL, GEMINI_EVENT_EXTRACTION_MODEL

# OpenAI is still supported as a fallback provider (set LLM_PROVIDER=openai and
# OPENAI_API_KEY to use it). Action/treatment-plan drafting uses the OpenAI
# Responses API and is a supporting, off-by-default feature.
# OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_ACTION_MODEL=gpt-4o-mini
OPENAI_ACTION_TIMEOUT_SECONDS=60
OPENAI_PLAN_MODEL=gpt-4o-mini
OPENAI_PLAN_TIMEOUT_SECONDS=60
OPENAI_RELEVANCE_FACTOR_MODEL=gpt-4o-mini
OPENAI_RELEVANCE_FACTOR_TIMEOUT_SECONDS=20
EVENT_SOURCE_MODE=REAL
EXTERNAL_EVENT_QUERY_LIMIT=3
REAL_EVENT_LOCATION_LIMIT=3
GDELT_ENABLED=true
GDELT_TIMEOUT_SECONDS=5
GDELT_CACHE_TTL_SECONDS=900
GDELT_STOP_ON_RATE_LIMIT=true
GDELT_HTTP_FALLBACK_ENABLED=true
OPEN_METEO_ENABLED=true
REAL_SEARCH_ENABLED=true
REAL_SEARCH_FEED_URLS=https://gcaptain.com/feed/,https://www.maritime-executive.com/articles.rss,https://splash247.com/feed/
REAL_SEARCH_TIMEOUT_SECONDS=5
REAL_SEARCH_MAX_RESULTS_PER_QUERY=5
OPEN_METEO_TIMEOUT_SECONDS=5
OPEN_METEO_FORECAST_DAYS=16
OPEN_METEO_VOYAGE_SAMPLE_LIMIT=6
TYPHOON_ENABLED=true
# TYPHOON_SOURCE_MODE: REAL (best-effort live feed) | MOCK (fixture track, demo) | OFF
TYPHOON_SOURCE_MODE=REAL
RISK_CALENDAR_ENABLED=true
POLICY_REGISTRY_ENABLED=true
